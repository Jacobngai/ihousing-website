      <th>Managed by iHousing</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Average occupancy</td>
      <td>50-58%</td>
      <td>62-72%</td>
    </tr>
    <tr>
      <td>Average response time</td>
